# ─── Bridge MS ───────────────────────────────────────────────────────────────
PORT=3003

# Clave que protege los endpoints internos (/whatsapp/enviar, /email/enviar, /estado/*)
# n8n debe enviar este valor en el header x-bridge-api-key
BRIDGE_API_KEY=cambia-esta-clave-secreta

# ─── n8n (self-hosted, corre en Docker) ──────────────────────────────────────
# URL interna del webhook de n8n que recibe los mensajes de Whapi
# Después de importar el workflow en n8n, copiar la URL del Webhook node aquí
N8N_WEBHOOK_URL=http://localhost:5678/webhook/primera-cita

# ─── Whapi ───────────────────────────────────────────────────────────────────
# Copiar del .env de clinica-segundo-parcial-sw2
WHAPI_BASE_URL=https://gate.whapi.cloud
WHAPI_TOKEN=

# ─── SMTP (Gmail) ────────────────────────────────────────────────────────────
# Copiar del .env de clinica-segundo-parcial-sw2
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Clínica MS (para el Code node de n8n — no usa el bridge directamente) ──
# Sólo necesario en el .env del workflow n8n (se configura en Variables de n8n)
# CLINICA_N8N_URL=http://localhost:3000
# N8N_API_KEY=<igual al N8N_API_KEY del .env de clinica>
